# --- SEC EDGAR ---------------------------------------------------------------
# REQUIRED by the SEC: a descriptive User-Agent including a contact email.
SEC_USER_AGENT="Your Name your-email@example.com"

# --- Voyage AI (embeddings + reranker) — https://dash.voyageai.com -----------
VOYAGE_API_KEY=

# --- Anthropic (agent layer, Phase 2) — https://console.anthropic.com --------
ANTHROPIC_API_KEY=

# --- Database ----------------------------------------------------------------
# docker-compose sets this automatically; only needed for non-compose local dev.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sec

# --- Optional overrides ------------------------------------------------------
# voyage-finance-2: finance-domain, 1024-dim, 50M free tokens (recommended here).
# voyage-4-lite: general, 1024-dim, 200M free tokens, cheapest at scale.
EMBED_MODEL=voyage-finance-2
EMBED_DIM=1024
RERANK_MODEL=rerank-2.5
LLM_MODEL=claude-sonnet-4-6
JUDGE_MODEL=claude-haiku-4-5
